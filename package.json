{
  "name": "evchargingstation-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=@evchargingstation/web",
    "dev:mobile": "npm run dev --workspace=@evchargingstation/mobile",
    "dev:desktop": "npm run dev --workspace=@evchargingstation/desktop",
    "build": "turbo run build",
    "build:web": "npm run build --workspace=@evchargingstation/web",
    "build:mobile": "npm run build --workspace=@evchargingstation/mobile",
    "build:desktop": "npm run build --workspace=@evchargingstation/desktop",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^1.10.12",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
