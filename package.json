{
  "name": "evchargingstation-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @evchargingstation/web dev",
    "dev:mobile": "pnpm --filter @evchargingstation/mobile dev",
    "dev:desktop": "pnpm --filter @evchargingstation/desktop dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @evchargingstation/web build",
    "build:mobile": "pnpm --filter @evchargingstation/mobile build",
    "build:desktop": "pnpm --filter @evchargingstation/desktop build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^1.10.12",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@8.0.0"
}
